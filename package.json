{
  "name": "jobsearch-skill",
  "version": "0.1.0",
  "description": "Local-first agent skill for turning job posts into reviewed application briefs.",
  "type": "module",
  "bin": {
    "jobsearch-skill": "bin/jobsearch-skill.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.js",
    "smoke": "node bin/jobsearch-skill.js fixtures/job-post.md --candidate fixtures/candidate-notes.md --format markdown",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "job-search",
    "career",
    "application-brief",
    "dry-run"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/jobsearch-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/jobsearch-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/jobsearch-skill#readme",
  "files": [
    "bin",
    "src",
    "fixtures",
    "docs",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ]
}
